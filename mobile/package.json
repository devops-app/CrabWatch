{
    "name":  "@crabwatch/mobile",
    "version":  "1.0.0+0018",
    "private":  true,
    "main":  "index.js",
    "scripts":  {
                    "dev":  "expo start",
                    "dev:ios":  "expo run:ios",
                    "dev:android":  "expo run:android",
                    "build:ios":  "npx eas-cli build --platform ios",
                    "build:android":  "npx eas-cli build --platform android",
                    "build:prod:ios":  "npx eas-cli build --platform ios --profile production",
                    "build:prod:android":  "npx eas-cli build --platform android --profile production",
                    "export":  "expo export --platform web",
                    "typecheck":  "npx tsc --noEmit",
                    "lint":  "eslint src --ext .ts,.tsx",
                    "lint:fix":  "eslint src --ext .ts,.tsx --fix",
                    "test":  "jest",
                    "test:watch":  "jest --watch",
                    "test:coverage":  "jest --coverage",
                    "android":  "expo run:android",
                    "ios":  "expo run:ios"
                },
