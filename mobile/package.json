{
  "name": "@crabwatch/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "dev:ios": "expo run:ios",
    "dev:android": "expo run:android",
    "build": "npx eas-cli build --platform all --non-interactive",
    "build:ios": "npx eas-cli build --platform ios --non-interactive",
    "build:android": "npx eas-cli build --platform android --non-interactive",
    "export": "expo export --platform web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@crabwatch/shared": "workspace:*",
    "babel-preset-expo": "~14.0.0",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^3.6.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "expo": "~54.0.0",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.0",
    "expo-font": "~14.0.0",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.0",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-screen-orientation": "~9.0.9",
    "expo-secure-store": "~15.0.8",
    "expo-sensors": "~15.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.52.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "zod": "^3.23.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "^20.0.0",
    "@types/react": "~19.1.10",
    "identity-obj-proxy": "^3.0.0",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "~29.7.0",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  }
