{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "@crabwatch/shared": ["shared/src"]
    }
  },
  "include": ["src", "shared/src"],
  "exclude": ["src/**/__tests__", "src/**/__mocks__", "shared/src/**/__tests__", "dist"]
}
