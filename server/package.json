{
    "name":  "@crabwatch/server",
    "version":  "1.0.1+0006",
    "private":  true,
    "engines":  {
                    "node":  "\u003e=22.0.0"
                },
    "scripts":  {
                    "dev":  "npx tsx watch src/index.ts",
                    "build":  "tsc",
                    "start":  "node dist/server/src/index.js",
                    "typecheck":  "npx tsc --noEmit",
                    "lint":  "eslint src --ext .ts",
                    "lint:fix":  "eslint . --ext .ts --fix",
                    "postinstall":  "npx prisma generate",
                    "db:generate":  "prisma generate",
                    "db:migrate":  "prisma migrate dev",
                    "db:migrate:deploy":  "prisma migrate deploy",
                    "db:studio":  "prisma studio",
                    "db:seed":  "npx tsx prisma/seed.ts",
                    "db:seed:i18n:ms":  "npx tsx src/services/seedMalayTranslations.ts",
                    "calibrate":  "npx tsx scripts/calibrateQuality.ts",
                    "qa:matrix":  "npx tsx scripts/runQAMatrix.ts",
                    "cleanup:broken":  "npx tsx scripts/cleanupBrokenObservations.ts",
                    "db:seed:test-users":  "npx tsx src/services/seedTestUsers.ts",
                    "test":  "jest",
                    "test:watch":  "jest --watch",
                    "test:coverage":  "jest --coverage"
                },
    "dependencies":  {
                         "@crabwatch/shared":  "workspace:*",
                         "@azure/monitor-opentelemetry":  "^1.18.1",
                         "@azure/storage-blob":  "^12.17.0",
                         "@prisma/client":  "5.22.0",
                         "bcryptjs":  "^2.4.3",
                         "compression":  "^1.8.1",
                         "cookie-parser":  "^1.4.7",
                         "cors":  "^2.8.5",
                         "dotenv":  "^16.4.5",
                         "express":  "^4.19.2",
                         "express-rate-limit":  "^7.2.0",
                         "firebase-admin":  "^12.1.0",
                         "heic-convert":  "^2.1.0",
                         "helmet":  "^7.1.0",
                         "i18next":  "^26.2.0",
                         "jsonwebtoken":  "^9.0.3",
                         "libheif-js":  "^1.19.8",
                         "multer":  "^2.2.0",
                         "pino":  "^10.3.1",
                         "pino-pretty":  "^13.1.3",
                         "resend":  "^6.12.3",
                         "sharp":  "^0.34.5",
                         "swagger-jsdoc":  "^6.2.8",
                         "swagger-ui-express":  "^5.0.1",
                         "zod":  "^3.23.0"
                     },
    "devDependencies":  {
                            "@types/bcryptjs":  "^2.4.6",
                            "@types/compression":  "^1.8.1",
                            "@types/cookie-parser":  "^1.4.10",
                            "@types/cors":  "^2.8.17",
                            "@types/express":  "^4.17.21",
                            "@types/jest":  "^30.0.0",
                            "@types/jsonwebtoken":  "^9.0.10",
                            "@types/multer":  "^2.1.0",
                            "@types/node":  "^20.19.39",
                            "@types/supertest":  "^7.2.0",
                            "@types/swagger-jsdoc":  "^6.0.4",
                            "@types/swagger-ui-express":  "^4.1.8",
                            "jest":  "^30.3.0",
                            "prisma":  "^5.14.0",
                            "supertest":  "^7.2.2",
                            "ts-jest":  "^29.4.9",
                            "tsx":  "^4.11.0",
                            "typescript":  "^5.5.0"
                        },
    "prisma":  {
                   "seed":  "npx tsx prisma/seed.ts"
               }
}