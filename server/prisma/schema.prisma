generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  role      UserRole @default(USER)
  avatar    String?
  password  String?
  firebaseUid String?  @unique
  createdAt DateTime @default(now())

  observations Observation[] @relation("UserObservations")
  validatedObs Observation[] @relation("ValidatedBy")
  fcmToken     FcmToken?
}

model FcmToken {
  id      String   @id @default(uuid()) @db.Uuid
  userId  String   @unique @db.Uuid
  token   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  USER
  RESEARCHER
  ADMIN
}

model Species {
  id                 String   @id @default(uuid())
  scientificName     String   @unique
  commonName         String
  description        String
  keyFeatures        Json
  images             Json
  distributionZones  Json

  observations Observation[]

  @@map("species")
}

model Observation {
  id                String              @id @default(uuid())
  userId            String   @db.Uuid
  speciesId         String
  cw                Float
  bw                Float?
  gender            Gender @map("sex")
  maturationStatus  MaturationStatus
  lat               Float
  lng               Float
  locationMethod    LocationMethod
  photos            Json
  detectedCoin      String?
  notes             String?
  status            ObservationStatus   @default(PENDING)
  validatedBy       String?  @db.Uuid
  validatedAt       DateTime?
  rejectionReason   String?
  createdAt         DateTime            @default(now())

  user         User    @relation("UserObservations", fields: [userId], references: [id])
  validator    User?   @relation("ValidatedBy", fields: [validatedBy], references: [id])
  species      Species @relation(fields: [speciesId], references: [id])

  @@index([userId])
  @@index([speciesId])
  @@index([status])
  @@index([createdAt])
  @@index([validatedBy])
  @@index([status, speciesId])
  @@index([status, createdAt])
  @@index([speciesId, status])
  @@map("observations")
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
  @@map("Sex")
}

enum MaturationStatus {
  MATURE
  IMMATURE
  UNKNOWN
}

enum LocationMethod {
  GPS
  MANUAL
}

enum ObservationStatus {
  PENDING
  APPROVED
  REJECTED
}
