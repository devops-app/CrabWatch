# Terraform Production Configuration
# Copy to production.tfvars and update values

environment = "production"
location    = "eastus"

# App Service
web_app_sku     = "P1v3"
api_app_sku     = "S1"

# Database
db_sku          = "GP_Gen5_2"
db_backup_retention = 35

# Redis
redis_sku       = "P1"

# Monitoring
app_insights_enabled = true
