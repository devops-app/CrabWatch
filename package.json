{
    "name":  "crabwatch",
    "private":  true,
    "version":  "1.0.0+0018",
    "description":  "Citizen science platform for mud crab conservation in Malaysia",
    "scripts":  {
                    "dev":  "pnpm -r --parallel dev",
                    "dev:server":  "pnpm --filter=server dev",
                    "dev:web":  "pnpm --filter=web dev",
                    "dev:mobile":  "pnpm --filter=mobile dev",
                    "build":  "pnpm -r build",
                    "build:server":  "pnpm --filter=server build",
                    "build:web":  "pnpm --filter=web build",
                    "build:mobile":  "pnpm --filter=mobile build",
                    "lint":  "pnpm -r lint",
                    "lint:fix":  "pnpm -r lint:fix",
                    "typecheck":  "npx tsc --noEmit -p shared/tsconfig.json \u0026\u0026 npx tsc --noEmit -p server/tsconfig.json \u0026\u0026 npx tsc --noEmit -p web/tsconfig.json \u0026\u0026 npx tsc --noEmit -p mobile/tsconfig.json",
                    "test:e2e":  "pnpm --filter=web test:e2e",
                    "test:e2e:ui":  "pnpm --filter=web test:e2e:ui",
                    "test:e2e:headed":  "pnpm --filter=web test:e2e:headed",
                    "test:e2e:install":  "pnpm --filter=web test:e2e:install",
                    "test:e2e:setup":  "pnpm --filter=server db:seed",
                    "test:e2e:ci":  "pnpm test:e2e:setup \u0026\u0026 concurrently -k -s first \"pnpm dev:server\" \"pnpm dev:web\" \"wait-on http://localhost:3001/health \u0026\u0026 pnpm test:e2e\"",
                    "test:e2e:teardown":  "pnpm --filter=server exec prisma db drop --force \u0026\u0026 docker compose down --remove-orphans",
                    "backup:db":  "bash scripts/backup-db.sh",
                    "clean":  "pnpm -r exec rm -rf node_modules dist .next",
                    "android":  "expo run:android",
                    "ios":  "expo run:ios"
                },
    "devDependencies":  {
                            "@typescript-eslint/eslint-plugin":  "^7.0.0",
                            "@typescript-eslint/parser":  "^7.0.0",
                            "concurrently":  "^8.2.2",
                            "eslint":  "^8.57.0",
                            "prettier":  "^3.3.0",
                            "typescript":  "^5.5.0",
                            "wait-on":  "^7.2.0"
                        },
    "packageManager":  "pnpm@10.33.2",
    "engines":  {
                    "node":  "\u003e=20.0.0",
                    "pnpm":  "\u003e=10.0.0"
                },
    "dependencies":  {
                         "expo":  "~54.0.35",
                         "react":  "19.1.0",
                         "react-native":  "0.81.5"
                     },
    "pnpm":  {
                 "overrides":  {
                                   "@babel/core":  "\u003e=7.29.6",
                                   "@grpc/grpc-js":  "\u003e=1.14.4",
                                   "@opentelemetry/core":  "\u003e=2.8.0",
                                   "esbuild":  "\u003e=0.28.1",
                                   "form-data":  "\u003e=4.0.6",
                                   "joi":  "\u003e=17.13.4",
                                   "js-yaml":  "\u003e=4.2.0",
                                   "postcss":  "\u003e=8.5.3",
                                   "protobufjs":  "\u003e=7.6.3",
                                   "shell-quote":  "\u003e=1.8.4",
                                   "tar":  "\u003e=7.5.16",
                                   "undici":  "6.27.0",
                                   "uuid":  "\u003e=11.1.0",
                                   "ws":  "\u003e=8.21.0"
                               }
             }
}